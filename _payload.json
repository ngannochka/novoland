vantage-3",{"title":44,"description":45,"icon":46},"advantages/advantage-3","26OkDV8RyI8Cre7Es2WB8YihwWXbAkQRAjUwD8J-COE",{"id":53,"title":54,"description":55,"extension":6,"icon":56,"meta":57,"stem":60,"__hash__":61},"advantages/advantages/advantage-4.json","Преимущество пластиковых ампул и монодоз","Возможность мелкого дозирования от 1 мл, простота вскрытия...","lucide:test-tube-diagonal",{"path":58,"body":59},"/advantages/advantage-4",{"title":54,"description":55,"icon":56},"advantages/advantage-4","kOCcV0CJEnKjNczLdj_Ns13jtf_A4Zcqu2WjTUHCL7Q",{"id":63,"title":64,"description":65,"extension":6,"icon":66,"meta":67,"stem":70,"__hash__":71},"advantages/advantages/advantage-5.json","Система менеджмента","Производство соответствует требованиям системы менеджмента безопасности...","lucide:user-check-2",{"path":68,"body":69},"/advantages/advantage-5",{"title":64,"description":65,"icon":66},"advantages/advantage-5","veA_46MM7p2Ew5RlpuLK3eLJK4F44vAraLuUgyiy7Rs",{"id":73,"title":74,"description":75,"extension":6,"icon":76,"meta":77,"stem":80,"__hash__":81},"advantages/advantages/advantage-6.json","Логистика","Выгодное географическое расположение производства обеспечивает...","lucide:truck",{"path":78,"body":79},"/advantages/advantage-6",{"title":74,"description":75,"icon":76},"advantages/advantage-6","xMEOTgUQFBJ92ynxcFBxu_0AqMmxnlWpISkX7Y-djkk",{"id":83,"description":84,"extension":6,"meta":85,"stem":88,"__hash__":89},"about/about/index.json","Компания «НовоЛэнд», основанная в 2019 году, является надежным партнером в сфере контрактного производства. Мы — единственный производитель на территории Сибири и Дальнего Востока, специализирующийся на выпуске пластиковых ампул и ламинатных туб. Полная автономия и контроль всех этапов производства — наш ключевой принцип: в нашем распоряжении собственные производственные цеха, современная лаборатория и складские помещения. Это позволяет управлять процессом от приемки сырья до отгрузки готовой продукции, обеспечивая стабильное качество и соответствие высоким стандартам. Мы предлагаем клиентам не просто услуги розлива, а комплексное решение, основанное на глубокой технологической экспертизе и безупречном контроле на каждом этапе производства.",{"path":86,"body":87,"title":10},"/about",{"description":84},"about/index","7t7fhB4FrdtUeJmg9o69UABeZY4LPqcaEhJJTjTkbAk",[91,101,110,119],{"id":92,"extension":6,"meta":93,"src":96,"stem":99,"to":97,"__hash__":100},"partners/partners/partner-1.json",{"path":94,"body":95,"title":98},"/partners/partner-1",{"src":96,"to":97},"https://s3.twcstorage.ru/f2f0a35f-e48e7736-24c2-4274-88c1-0854b97bbed7/partner-1.png","https://google.com/","Partner 1","partners/partner-1","qSodmQI8T-NXkNJYEP34NfiR9xtMbXalaU-ung3S6QY",{"id":102,"extension":6,"meta":103,"src":106,"stem":108,"to":97,"__hash__":109},"partners/partners/partner-2.json",{"path":104,"body":105,"title":107},"/partners/partner-2",{"src":106,"to":97},"https://s3.twcstorage.ru/f2f0a35f-e48e7736-24c2-4274-88c1-0854b97bbed7/partner-2.png","Partner 2","partners/partner-2","vTYGq5kh2oPA2W9dscTWtEnppr3Mx7tr3gvqYQffEzM",{"id":111,"extension":6,"meta":112,"src":115,"stem":117,"to":97,"__hash__":118},"partners/partners/partner-3.json",{"path":113,"body":114,"title":116},"/partners/partner-3",{"src":115,"to":97},"https://s3.twcstorage.ru/f2f0a35f-e48e7736-24c2-4274-88c1-0854b97bbed7/partner-3.png","Partner 3","partners/partner-3","u7uMUHoNohwzpc-LGtsQvs47SWLQqM1LCVCevDeTbik",{"id":120,"extension":6,"meta":121,"src":124,"stem":126,"to":97,"__hash__":127},"partners/partners/partner-4.json",{"path":122,"body":123,"title":125},"/partners/partner-4",{"src":124,"to":97},"https://s3.twcstorage.ru/f2f0a35f-e48e7736-24c2-4274-88c1-0854b97bbed7/partner-4.png","Partner 4","partners/partner-4","5aQ83bigxb-3VwpIhxPDDmb2Yf2GpjWFiHU1xfAivRQ",[129,139,149,159,169,179],{"id":130,"description":131,"extension":6,"icon":132,"meta":133,"stem":137,"__hash__":138},"accomplishments/accomplishments/accomplishment-1.json","Являемся членами междуна